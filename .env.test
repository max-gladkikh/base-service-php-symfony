# задаём название проекта (https://docs.docker.com/compose/environment-variables/envvars/)
COMPOSE_PROJECT_NAME=base_public
PROJECT_URL=base.localhost

# Настройки Nginx
NGINX_VERSION=1.29.3
DOCKER_NGINX_VERSION=${NGINX_VERSION}-trixie
NGINX_HOST=${PROJECT_URL}
NGINX_PORT_80=80
NGINX_OUTER_PORT_80=80
NGINX_PORT_443=443
NGINX_OUTER_PORT_443=443
ROOT_DIR=/home/${NGINX_HOST}
NGINX_ROOT_DIR=${ROOT_DIR}/www
NGINX_LOG_DIR=/var/log/nginx
NGINX_SSL_DIR=/etc/nginx/ssl

# For git
# Имя и email пользователя гита и разработчика данного сервиса
PROJECT_USER_NAME='test test'
PROJECT_USER_EMAIL=test@gmail.com

###> symfony/framework-bundle ###
# dev or test or prod (Symfony var name)
# для успешного запуска сервиса, необходимо чтобы в файлах сервиса присутствовал файл php.ini для дев и прод окружения в папке php/
APP_ENV=test
APP_SECRET=test_secret
KERNEL_CLASS='App\Kernel'
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=https://${PROJECT_URL}
###< symfony/routing ###

###> symfony/messenger ###
# https://symfony.com/doc/current/messenger.html#messenger-transports-config
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

# Docker network
SERVICE_NETWORK_NAME=${COMPOSE_PROJECT_NAME}_network

# Временная зона
# WORKSPACE_TIMEZONE=Asia/Yekaterinburg

# Настройки Postgres
POSTGRES_PROJECT_DB=${COMPOSE_PROJECT_NAME}_db                  # тут нельзя тире/дефисы вот эти -
POSTGRES_PROJECT_USER=${COMPOSE_PROJECT_NAME}_user              # тут нельзя тире/дефисы вот эти -
POSTGRES_PASSWORD=${COMPOSE_PROJECT_NAME}_password
POSTGRES_PROJECT_IMAGE=${COMPOSE_PROJECT_NAME}_postgres
POSTGRES_PROJECT_HOST=postgres_host # название как у сервиса в docker-compose.yml
# POSTGRES_PROJECT_HOST=172.17.0.1
# Если постгрес запущен в другой сети контейнеров,
# смотрим Gateway этой сети docker network inspect {NETWORK_NAME}
# и пишем его в значение POSTGRES_PROJECT_HOST.
# По умолчанию у сети bridge Gateway = 172.17.0.1
# и пока эта сеть существует, мы можем подключаться к базе через него

POSTGRES_PORT=5432
POSTGRES_OUTER_PORT=5432
POSTGRES_PROJECT_CHARSET=utf8
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256
# Наследуемся от официального докер образа postgres
# https://hub.docker.com/_/postgres
POSTGRES_PROJECT_VERSION=18.3
PG_ALLVERSIONS_DATA=/var/lib/postgresql # for postgres versions 18+
#PG_ALLVERSIONS_DATA=/var/lib/postgresql/data # for postgres versions before 18

DATABASE_URL="postgresql://$POSTGRES_PROJECT_USER:$POSTGRES_PASSWORD@$POSTGRES_PROJECT_HOST:$POSTGRES_OUTER_PORT/$POSTGRES_PROJECT_DB?serverVersion=$POSTGRES_PROJECT_VERSION&charset=$POSTGRES_PROJECT_CHARSET"

DUMP_DB_URL="postgresql://$POSTGRES_PROJECT_USER:$POSTGRES_PASSWORD@$POSTGRES_PROJECT_HOST:$POSTGRES_OUTER_PORT/$POSTGRES_PROJECT_DB"

###### Настройки PHP
PHP_PROJECT_IMAGE=${COMPOSE_PROJECT_NAME}_php
PHP_PROJECT_HOST=php_host # название как у сервиса в docker-compose.yml
# Версия php, смотреть и выбирать тут https://hub.docker.com/_/php
# Для выбранной вами версии php должна присутствовать папка с конфигурацией php.ini для дев и прод окружения в папке php/
# Если для выбранной вами версии php нет такой папки, вам необходимо будет добавить эту папку и сами файлы конфигурации.
# Для этого при первом запуске контейнера с новой версией php, зайдите в него, зайдите в папку /usr/local/etc/php, там будут находиться файлы php.ini-development и php.ini-production, скопируйте их содержимое.
# Так же рекомендуется раскоментить в php.ini-prod zend_extension=opcache (https://hub.docker.com/_/php)
PHP_PROJECT_VERSION=8.4.14
DOCKER_PHP_VERSION=${PHP_PROJECT_VERSION}-fpm-trixie
# Порт php-fpm по умолчанию
PHPFPM_PORT=9000
# Внешний порт php-fpm
PHPFPM_OUTER_PORT=9000
#COMPOSER HASH смотреть тут https://getcomposer.org/download/
COMPOSER_HASH=c8b085408188070d5f52bcfe4ecfbee5f727afa458b2573b8eaaf77b3419b0bf2768dc67c86944da1544f06fa544fd47

REDIS_IMAGE=redis
REDIS_VERSION=7.2.7-alpine
#REDIS_CONTAINER_NAME=redis_host
REDIS_PORT=6379
REDIS_OUTER_PORT=6379
REDIS_PROJECT_HOST=redis_host
REDIS_URL="redis://$REDIS_PROJECT_HOST:$POSTGRES_OUTER_PORT"
